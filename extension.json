{
	"manifest_version": 2,
	"name": "Trending",
	"description": "Implements trending articles.",
	"author": ["[https://wikux.org Wikux]"],
	"version": "0.1.0",
	"license-name": "GPL-3.0-or-later",
	"url": "https://github.com/wikux/mediawiki-extensions-Trending",

	"type": "variable",

	"requires": {
		"MediaWiki": ">=1.43.0"
	},

	"suggests": {
		"extensions": {
			"HitCounters": ">=0.4.0",
			"PageImages": "*",
			"ShortDescription": "*"
		}
	},

	"AutoloadClasses": {
		"MediaWiki\\Extension\\Trending\\Hooks": "src/Hooks.php",
		"MediaWiki\\Extension\\Trending\\ExtensionConfig": "src/ExtensionConfig.php",
		"MediaWiki\\Extension\\Trending\\PageViewCounter": "src/PageViewCounter.php",
		"MediaWiki\\Extension\\Trending\\PageViewCountUpdate": "src/PageViewCountUpdate.php",
		"MediaWiki\\Extension\\Trending\\PageViewFooterItem": "src/PageViewFooterItem.php",
		"MediaWiki\\Extension\\Trending\\TrendingQuery": "src/TrendingQuery.php",
		"MediaWiki\\Extension\\Trending\\CategoryPopularBlock": "src/CategoryPopularBlock.php",
		"MediaWiki\\Extension\\Trending\\CategoryPopularListBlock": "src/CategoryPopularListBlock.php",
		"MediaWiki\\Extension\\Trending\\CategoryTrendingGridBlock": "src/CategoryTrendingGridBlock.php",
		"MediaWiki\\Extension\\Trending\\TrendingPageMedia": "src/TrendingPageMedia.php",
		"MediaWiki\\Extension\\Trending\\SkinHelper": "src/SkinHelper.php",
		"MediaWiki\\Extension\\Trending\\TrendingCategoryPage": "src/TrendingCategoryPage.php"
	},

	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],

	"MessagesDirs": {
		"Trending": "i18n"
	},

	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "Trending"
	},

	"ResourceModules": {
		"ext.trending.citizenGrid.styles": {
			"styles": "resources/ext.trending.citizenGrid.styles.css",
			"targets": ["desktop", "mobile"]
		}
	},

	"Hooks": {
		"ArticleFromTitle": "MediaWiki\\Extension\\Trending\\Hooks::onArticleFromTitle",
		"BeforePageDisplay": "MediaWiki\\Extension\\Trending\\Hooks::onBeforePageDisplay",
		"LoadExtensionSchemaUpdates": "MediaWiki\\Extension\\Trending\\Hooks::onLoadExtensionSchemaUpdates",
		"PageViewUpdates": "MediaWiki\\Extension\\Trending\\Hooks::onPageViewUpdates",
		"SkinAddFooterLinks": "MediaWiki\\Extension\\Trending\\Hooks::onSkinAddFooterLinks",
		"SkinTemplateNavigation::Universal": "MediaWiki\\Extension\\Trending\\Hooks::onSkinTemplateNavigation__Universal"
	},

	"config": {
		"PageViewCountDataSource": {
			"value": "Trending",
			"description": "The data source for page view counts. Use `HitCounters` for the HitCounters extension if you already have it installed."
		},
		"TrendingCategoryLimit": {
			"value": 10,
			"description": "Maximum number of popular pages to show on category pages."
		},
		"TrendingShowCounts": {
			"value": true,
			"description": "Whether to display view counts next to popular page links on category pages."
		},
		"TrendingCitizenLimit": {
			"value": 6,
			"description": "Maximum number of trending pages to show in the Citizen skin thumbnail grid."
		},
		"TrendingCitizenThumbSize": {
			"value": 320,
			"description": "Maximum thumbnail width in pixels for the Citizen skin trending grid."
		}
	}
}
